MC_HOST=ranmc.cc
MC_PORT=25565

# 留空就是每次启动随机普通玩家昵称和密码；本次运行的重连会继续使用同一组。
MC_USERNAME=
MC_PASSWORD=

# 默认走本机 7897 代理。Clash/Mihomo 常见 mixed/http 端口可把类型改成 http。
MC_PROXY_TYPE=socks5
MC_PROXY_HOST=127.0.0.1
MC_PROXY_PORT=7897

# 用于解析 Minecraft SRV 记录；ranmc.cc 的真实入口来自 SRV。
MC_DNS_SERVERS=223.5.5.5,119.29.29.29,8.8.8.8

# offline 适合需要 /reg 和 /login 的离线服务器；正版服可改成 microsoft。
MC_AUTH=offline

# ranmc.cc 当前 ping 返回协议 774，默认用 1.21.11。
MC_VERSION=1.21.11

# false 可关闭自动 /reg 和 /login。
MC_AUTO_AUTH=true
MC_REGISTER_COMMAND=/reg
MC_LOGIN_COMMAND=/login

# 无限重连，不限制次数。这里仅控制每次断线后的等待时间。
MC_RECONNECT_DELAY_MS=5000

# 放宽 keepalive 检查，避免服务器短时卡顿时客户端自己断开。
MC_CHECK_TIMEOUT_MS=120000
